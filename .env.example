# Copy to .env and fill in, then: `set -a; source .env; set +a` before running.
# Either set a full DB_URL...
# DB_URL=mysql+mysqlconnector://root:secret@127.0.0.1:3306/todos

# ...or the individual parts (used when DB_URL is not set):
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=todos
